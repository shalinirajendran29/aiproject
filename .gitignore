# =============================================================================
# Master .gitignore — Intelligent Form Automation Platform
# =============================================================================

# -------------------------------------------------------------------
# Python
# -------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Test / type-check / coverage caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
.cache/
nosetests.xml
coverage.xml
*.cover

# -------------------------------------------------------------------
# Environment / secrets
# -------------------------------------------------------------------
.env
*.env
.env.*
!.env.example
backend/.env
auth.json
*.pem
*.key

# -------------------------------------------------------------------
# Databases & local data
# -------------------------------------------------------------------
*.db
*.db-journal
*.sqlite
*.sqlite3
sql_app.db

# -------------------------------------------------------------------
# Uploads / generated runtime artifacts
# -------------------------------------------------------------------
uploads/
backend/uploads/
debug_result_screenshot.png
*_debug.png

# -------------------------------------------------------------------
# Node.js / frontend
# -------------------------------------------------------------------
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.vite/

# -------------------------------------------------------------------
# Machine-learning models & weights (large binaries)
# -------------------------------------------------------------------
*.pt
*.pth
*.onnx
*.bin
*.safetensors
models/
.ollama/

# -------------------------------------------------------------------
# IDE / editor
# -------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -------------------------------------------------------------------
# Operating system files
# -------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# -------------------------------------------------------------------
# Cloud-sync mis-pushes (never commit a synced copy of the project)
# -------------------------------------------------------------------
OneDrive/
**/OneDrive/

# -------------------------------------------------------------------
# Logs & temp
# -------------------------------------------------------------------
*.log
logs/
tmp/
temp/
